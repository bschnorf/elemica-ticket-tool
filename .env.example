# Copy to .env and fill in. Never commit .env.
# All values optional for local dev — the stubs work without keys.

# --- Anthropic (for the AI Triage / PR / Reply TODOs) ---
ANTHROPIC_API_KEY=

# --- Jira (Block 2 — replace mock data with a real fetch) ---
JIRA_BASE_URL=https://elemica.atlassian.net
JIRA_EMAIL=you@elemica.com
JIRA_API_TOKEN=

# --- Server ---
PORT=3000

# --- Auth ---
# Shared password gating the UI. If unset, the app runs without auth (dev mode).
APP_PASSWORD=
# Random hex string used to sign the session cookie. Generate with `openssl rand -hex 32`.
# If unset, a fresh secret is generated at startup — sessions invalidate on every restart.
SESSION_SECRET=
